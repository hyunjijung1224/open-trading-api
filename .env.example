# ================================================
# Phase 1 설정 — 1억원 / 모의투자
# ================================================

# ── 한국투자증권 모의투자 ──────────────────────────
KIS_APP_KEY=여기에_앱키_입력
KIS_APP_SECRET=여기에_앱시크릿_입력
KIS_ACCOUNT_NO=12345678-01
KIS_IS_PAPER=true                   # ★ 반드시 true

# Paper 환경에서 종목명 조회(CTPF1604R)는 실서버만 지원.
# 실전투자 앱키/시크릿을 아래에 입력하면 Paper 모드에서도 정확한 종목명 검증 가능.
# (없어도 폴백으로 동작하지만 삼성전자·SK하이닉스 등 KIS 검증 실패 경고가 반복됨)
KIS_REAL_APP_KEY=여기에_실전투자_앱키_입력
KIS_REAL_APP_SECRET=여기에_실전투자_앱시크릿_입력


# ── Gemini ────────────────────────────────────────
GEMINI_API_KEY=여기에_Gemini_API키_입력

# ── Finnhub (해외 뉴스 수집용, 무료 티어) ─────────────
# https://finnhub.io/ 가입 후 API 키 발급 (무료: 60 calls/minute)
FINNHUB_API_KEY=여기에_Finnhub_API키_입력
FRED_API_KEY=14782ac5ad1e6908e1a457a418a19a0f

# ── Telegram ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=여기에_봇토큰_입력
TELEGRAM_CHAT_ID=여기에_chat_id_입력

# ── Google Sheets ─────────────────────────────────
GOOGLE_SHEET_ID=여기에_시트ID_입력
GOOGLE_CREDENTIALS_JSON=credentials.json

# ── MariaDB ───────────────────────────────────────
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=kis_user
MARIADB_PASSWORD=여기에_비밀번호_입력
MARIADB_DATABASE=kis_trading

# ── 자금 (1억) ───────────────────────────────────
TOTAL_CAPITAL=100000000
MAX_PORTFOLIO_SIZE=5
MAX_POSITION_RATIO=0.20
STOP_LOSS_RATIO=-0.05
TAKE_PROFIT_RATIO=0.15
TRAILING_STOP_RATIO=-0.03

# ── DART 폴링 ────────────────────────────────────
DART_POLL_INTERVAL=300
DART_LOOKBACK_HOURS=2

# ── 신호 엔진 ────────────────────────────────────
SCORE_BUY_THRESHOLD=65
VOLUME_SPIKE_THRESH=2.5
CHANGE_RATE_MAX=6.0
